{
  "expo": {
    "name": "Pragmabiz Warehouse",
    "slug": "pragmabiz-warehouse-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "pragmabiz-warehouse",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.pragmatica.pragmabiz.warehouse"
    },
    "android": {
      "package": "app.pragmatica.pragmabiz.warehouse",
      "adaptiveIcon": {
        "backgroundColor": "#8d73cf"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-camera",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "62ef073e-51b5-442c-b5fd-134a69fb2aa5"
      }
    }
  }
}
