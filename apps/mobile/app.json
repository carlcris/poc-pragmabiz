{
  "expo": {
    "name": "Pragmabiz Warehouse",
    "slug": "pragmabiz-warehouse-mobile",
    "version": "0.1.0",
    "orientation": "default",
    "userInterfaceStyle": "light",
    "scheme": "pragmabiz-warehouse",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.pragmatica.pragmabiz.warehouse"
    },
    "android": {
      "package": "app.pragmatica.pragmabiz.warehouse",
      "adaptiveIcon": {
        "backgroundColor": "#8d73cf"
      }
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-camera"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
